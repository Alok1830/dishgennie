SECRET_KEY=change-this-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Razorpay (Payment Gateway)
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=placeholder_secret

# Gmail SMTP (for OTP emails)
# Generate an App Password: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password

# Production Database (required for Vercel / Render)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ─── Vercel Environment Variables ──────────────────────────────
# Set these in the Vercel Dashboard → Project → Settings → Environment Variables:
#
#   SECRET_KEY          — A strong random string
#   DEBUG               — False
#   DATABASE_URL        — Your hosted PostgreSQL connection string (e.g. Neon, Supabase, Railway)
#   EMAIL_HOST_USER     — Your Gmail address (e.g. dishgennie.web@gmail.com)
#   EMAIL_HOST_PASSWORD — Your 16-char Gmail App Password
#   ALLOWED_HOSTS       — your-project.vercel.app (comma-separated)
#
# The VERCEL env var is automatically set by Vercel — no need to add it manually.
